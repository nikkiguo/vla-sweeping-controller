<mujoco>
    <!-- Define the coordinate system -->
    <compiler angle="degree" coordinate="local"/>
    <option integrator="Euler" timestep="0.002" gravity="0 0 -9.81"/>
    
    <statistic center="0 -0.15 0.4" extent="0.8"/>

    <!-- Include the UR5e robot model -->
    <include file="ur5e.xml"/>

    <!-- Visuals and Assets -->
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <worldbody>
        <!-- Floor -->
        <geom name="floor" type="plane" size="1 1 0.01" pos="0 0 0" material="groundplane"/>
        
        <!-- Red Square Puck -->
        <body name="red_box" pos="0.2 -0.4 0.2">
            <joint type="free"/>
            <geom type="box" size="0.05 0.05 0.05" rgba="1 0 0 1" friction="0.2 0.05 0.001"/>
        </body>

        <!-- Blue Circular Puck -->
        <body name="blue_puck" pos="0.0 -0.4 0.2">
            <joint type="free"/>
            <geom type="cylinder" size="0.05 0.05" rgba="0 0 1 1" friction="0.2 0.05 0.001"/>
        </body>

        <!-- Green Square Puck -->
        <body name="green_puck" pos="-0.2 -0.4 0.2">
            <joint type="free"/>
            <geom type="box" size="0.05 0.05 0.05" rgba="0 1 0 1" friction="0.2 0.05 0.001"/>
        </body>
    </worldbody>
</mujoco>